# Copia este archivo como .env y rellena los valores reales.
# Nunca comitas .env — sólo .env.example va al repo.

# ── Stripe Payment Links ─────────────────────────────────────
# Crea los Payment Links en dashboard.stripe.com → Payment Links
# Local: usa links de TEST mode (buy.stripe.com/test_...)
# Producción (Netlify env vars): usa links de LIVE mode (buy.stripe.com/...)
PUBLIC_STRIPE_LINK_COMPARTIDA=https://buy.stripe.com/test_XXXXXXXXXXXXXXXXXXXXXXXX
PUBLIC_STRIPE_LINK_INDIVIDUAL=https://buy.stripe.com/test_XXXXXXXXXXXXXXXXXXXXXXXX
