---
import { Image } from 'astro:assets';
import heroPhoto from '../assets/images/ruralia-1.jpg';
import Base from '../layouts/Base.astro';

const linkCompartida = import.meta.env.PUBLIC_STRIPE_LINK_COMPARTIDA;
const linkIndividual  = import.meta.env.PUBLIC_STRIPE_LINK_INDIVIDUAL;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ruralGPT',
  url: 'https://ruralgpt.gal',
  description: 'Retiro inmersivo de IA aplicada para profesionales. 4 días en Galicia.',
  foundingDate: '2026',
  sameAs: [],
};

const days = [
  {
    num: '01',
    title: '¿Dónde estoy?',
    subtitle: 'Mapa del terreno',
    desc: 'Qué herramientas existen, para qué sirve cada una, cuáles son humo y cuáles merecen tu tiempo.',
  },
  {
    num: '02',
    title: '¿Qué puedo automatizar?',
    subtitle: 'Tu trabajo bajo la lupa',
    desc: 'Analizamos tu flujo de trabajo real. Qué tareas puedes automatizar, delegar a IA o hacer en la mitad de tiempo.',
  },
  {
    num: '03',
    title: '¿Puedo construir cosas?',
    subtitle: 'De idea a prototipo',
    desc: 'Aunque no sepas programar. Con Cursor, Bolt, Lovable y v0 construyes herramientas que antes habrías encargado.',
  },
  {
    num: '04',
    title: '¿Con qué me quedo?',
    subtitle: 'Tu stack personalizado',
    desc: 'Montas tu kit definitivo. Sales con todo configurado y listo para volver al trabajo con IA.',
  },
];

const team = [
  { name: 'Agustín Jamardo', bio: 'Fundador de Anceu Coliving. Desarrollador, 12+ años en remoto.' },
  { name: 'África Rodríguez', bio: 'Cofundadora de Rural Hackers. Facilitadora de proyectos europeos (Erasmus+).' },
  { name: 'Nacho Márquez', bio: 'Cofundador de Rural Hackers. Director de Noites Abertas. 20+ proyectos internacionales.' },
];

const inclusions = [
  '4 días de formación práctica',
  '3 noches de alojamiento',
  'Todas las comidas incluidas',
  'Materiales y licencias',
  'Comunidad alumni',
  'Sesión de seguimiento online',
];


const tools = [
  { name: 'ChatGPT', desc: 'Probablemente ya la uses. Aquí vas mucho más allá del 10% de su capacidad.', logo: '/logos/openai.svg', href: 'https://chatgpt.com' },
  { name: 'Claude', desc: 'Para razonamiento y documentos largos. Mejor que ChatGPT para ciertas tareas.', logo: '/logos/anthropic.svg', href: 'https://claude.ai' },
  { name: 'Gemini', desc: 'La IA de Google. Integrada con Gmail, Docs y Drive.', logo: '/logos/googlegemini.svg', href: 'https://gemini.google.com' },
  { name: 'Cursor', desc: 'Escribe código con IA como copiloto. Aunque no sepas programar.', logo: '/logos/cursor.svg', href: 'https://cursor.com' },
  { name: 'Bolt', desc: 'De idea a prototipo en minutos. Para validar antes de invertir tiempo.', logo: '/logos/bolt.svg', href: 'https://bolt.new' },
  { name: 'Lovable', desc: 'Crea aplicaciones web completas describiendo lo que necesitas.', logo: '/logos/lovable.svg', href: 'https://lovable.dev' },
  { name: 'v0', desc: 'Genera componentes de interfaz con una descripción. Para diseñadores y devs.', logo: '/logos/vercel.svg', href: 'https://v0.dev' },
  { name: 'Make', desc: 'Automatiza flujos entre aplicaciones. Sin programar.', logo: '/logos/make.svg', href: 'https://make.com' },
  { name: 'Perplexity', desc: 'Búsqueda con IA que cita las fuentes. Para investigar sin perderse.', logo: '/logos/perplexity.svg', href: 'https://perplexity.ai' },
  { name: 'NotebookLM', desc: 'Convierte documentos en una base de conocimiento interactiva.', logo: '/logos/notebooklm.svg', href: 'https://notebooklm.google.com' },
  { name: 'Runway', desc: 'Genera y edita vídeo con IA. Para los que trabajan con contenido.', logo: '/logos/runway.svg', href: 'https://runwayml.com' },
  { name: 'Kimi 2.5', desc: 'Modelo open source potente de Moonshot AI. Para tareas avanzadas.', logo: '/logos/kimi.svg', href: 'https://kimi.ai' },
];
---

<Base
  title="ruralGPT — Retiro inmersivo de IA aplicada en Galicia"
  description="4 días en Galicia para ponerte al día con IA. Formación práctica, alojamiento y comidas incluidas. 12 plazas. 3–7 junio 2026."
  keywords={['retiro IA España', 'curso IA inmersivo', 'formación IA Galicia', 'retiro inteligencia artificial']}
  schema={schema}
  hideHeader={true}
>

  <!-- ===== NAV ===== -->
  <header class="nav">
    <a href="/" class="nav-logo">ruralGPT</a>
    <nav class="nav-links" id="home-nav">
      <a href="/retiro-ia-galicia/">El retiro</a>
      <a href="/para-quien/">Para quién</a>
      <a href="/blog/">Blog</a>
      <a href="/faq/">FAQ</a>
    </nav>
    <a href="/#pricing" class="nav-cta">Reservar</a>
    <button class="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="home-nav">
      <span></span>
      <span></span>
    </button>
  </header>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-top">
      <h1 class="hero-headline">¿TE ACUERDAS DEL RINCÓN DEL VAGO?</h1>
    </div>
    <div class="hero-sub">
      <div class="hero-sub-text">
        <p>Un retiro inmersivo de IA aplicada en Galicia. 4 días, 12 plazas, todo incluido.</p>
        <p class="hero-date">3 – 7 junio 2026 · Anceu Coliving, Pontevedra</p>
      </div>
      <a href="/#pricing" class="btn-dark">Reserva tu plaza</a>
    </div>
    <div class="hero-photo">
      <Image
        src={heroPhoto}
        alt="Anceu Coliving entre árboles con niebla matutina en Galicia"
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- ===== EL RUIDO ===== -->
  <section class="section noise">
    <div class="noise-grid">
      <div class="noise-left">
        <p class="tag">El ruido</p>
        <p>Cada semana salen 3 herramientas de IA nuevas. Los profesionales no tienen tiempo de probarlas. La brecha entre lo que saben y lo que deberían saber crece. No es falta de capacidad — es falta de horas.</p>
      </div>
      <div class="noise-right">
        <p class="noise-stmt">Todos los que usamos el Rincón del Vago recordamos esa sensación de alivio al encontrar el camino corto.</p>
        <hr class="noise-rule" />
        <p class="noise-stmt">Nuestra propuesta te hará sentir lo mismo, pero sin el miedo a que te pillen.</p>
        <hr class="noise-rule" />
        <p class="noise-stmt">En 4 días eliminarás la fatiga por herramientas: separar lo que funciona de lo que es humo.</p>
      </div>
    </div>
  </section>

  <!-- ===== PROTOCOLO 4 DÍAS ===== -->
  <section class="section protocol">
    <h2 class="protocol-h">El protocolo de 4 días</h2>
    <div class="protocol-grid">
      {days.map((day) => (
        <div class="protocol-card">
          <span class="protocol-num">{day.num}</span>
          <div class="protocol-body">
            <h3 class="protocol-title">{day.title}</h3>
            <p class="protocol-sub">{day.subtitle}</p>
            <p class="protocol-desc">{day.desc}</p>
          </div>
          <span class="protocol-plus">+</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== HERRAMIENTAS ===== -->
  <section class="section tools">
    <p class="tag">Herramientas que aprenderás a usar</p>
    <div class="tools-grid">
      {tools.map((tool) => (
        <a class="tool-card" href={tool.href} target="_blank" rel="noopener noreferrer">
          <div class="tool-top">
            <img class="tool-logo" src={tool.logo} alt={tool.name} width="28" height="28" loading="lazy" />
            <span class="tool-arrow">↗</span>
          </div>
          <p class="tool-name">{tool.name}</p>
          <p class="tool-desc">{tool.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ===== ARQUITECTURA DEL RETIRO ===== -->
  <section class="section arch">
    <p class="tag tag-italic">La arquitectura del retiro</p>
    <div class="arch-grid">
      <div class="arch-main">
        <Image
          src={heroPhoto}
          alt="Gastronomía gallega en Anceu"
          widths={[800, 1200]}
          sizes="(max-width: 768px) 100vw, 60vw"
          loading="lazy"
        />
      </div>
      <div class="arch-side">
        <div class="arch-card">
          <p class="arch-card-title">Alojamiento</p>
          <p class="arch-card-desc">3 noches en Anceu Coliving. Habitación privada incluida.</p>
        </div>
        <div class="arch-card arch-card-dark">
          <p class="arch-card-title">Anceu Coliving</p>
          <p class="arch-card-desc">Pontevedra, Galicia. 1 Gbps. A 30 min de la ciudad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PRICING ===== -->
  <section class="section" id="pricing">
    <div class="section-inner pricing-section">
      <h2>Precio</h2>
      <p class="pricing-intro">Todo incluido: formación, alojamiento, comidas y comunidad alumni.</p>
      <div
        class="pricing-grid"
        data-prices='[
          {"until":"2026-03-16","label":"Early bird","until_text":"hasta el 15 de marzo","discount":"30% de descuento","compartida":442,"individual":558},
          {"until":"2026-04-16","label":"Segunda tanda","until_text":"hasta el 15 de abril","discount":"15% de descuento","compartida":537,"individual":677},
          {"until":null,"label":"Precio normal","until_text":"","discount":"","compartida":632,"individual":797}
        ]'
      >
        <div class="price-card" id="card-compartida">
          <div class="room-title">Habitación compartida</div>
          <div class="room-subtitle">Compartida con otra persona</div>
          <span class="price-amount" id="price-compartida">442 EUR</span>
          <span class="price-tier" id="tier-compartida">Early bird — hasta el 15 de marzo</span>
          <span class="price-discount" id="discount-compartida">30% de descuento</span>
          <ul>
            <li>4 días de formación</li>
            <li>3 noches de alojamiento</li>
            <li>Todas las comidas</li>
            <li>Comunidad alumni</li>
            <li>Sesión follow-up</li>
          </ul>
          <p class="deposit-note">100 € ahora · resto antes de la llegada</p>
          <a href={linkCompartida} class="btn btn-primary" target="_blank" rel="noopener">Reserva por 100 €</a>
        </div>
        <div class="price-card featured" id="card-individual">
          <div class="room-title">Habitación individual</div>
          <div class="room-subtitle">Habitación para ti solo</div>
          <span class="price-amount" id="price-individual">558 EUR</span>
          <span class="price-tier" id="tier-individual">Early bird — hasta el 15 de marzo</span>
          <span class="price-discount" id="discount-individual">30% de descuento</span>
          <ul>
            <li>4 días de formación</li>
            <li>3 noches de alojamiento</li>
            <li>Todas las comidas</li>
            <li>Comunidad alumni</li>
            <li>Sesión follow-up</li>
          </ul>
          <p class="deposit-note">150 € ahora · resto antes de la llegada</p>
          <a href={linkIndividual} class="btn btn-gold" target="_blank" rel="noopener">Reserva por 150 €</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== EQUIPO ===== -->
  <section class="section team">
    <div class="team-grid">
      {team.map((person) => (
        <div class="team-card">
          <div class="team-photo"></div>
          <p class="team-name">{person.name}</p>
          <p class="team-bio">{person.bio}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <section class="cta-final">
    <h2 class="cta-headline">El día 5 vuelves<br/>a tu trabajo.<br/>Pero diferente.</h2>
    <p class="cta-sub">Mismo escritorio. Mismos clientes. Pero con IA integrada en tu flujo de trabajo. 12 plazas. Junio 2026.</p>
    <a href="/#pricing" class="btn-cta-final">Reserva tu plaza</a>
  </section>

</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');

  /* ============================================================
     TOKENS
  ============================================================ */
  :root {
    --black: #000000;
    --white: #ffffff;
    --gray-light: #f2f2f2;
    --gray-mid: #e0e0e0;
    --gray-text: #555555;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --max: 1200px;
    --pad: clamp(1.5rem, 5vw, 4rem);
  }

  /* ============================================================
     NAV
  ============================================================ */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.25rem var(--pad);
    background: var(--white);
    border-bottom: 1px solid var(--gray-mid);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--black);
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-right: auto;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    font-size: 0.85rem;
    color: var(--gray-text);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--black); }
  .nav-cta {
    background: var(--black);
    color: var(--white);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .nav-cta:hover { opacity: 0.75; color: var(--white); }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--black);
  }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-cta { display: none; }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 1px solid #e0e0e0;
      flex-direction: column;
      padding: 1rem clamp(1.5rem, 5vw, 4rem);
      gap: 0;
      z-index: 99;
    }
    .nav-links.open { display: flex; }
    .nav-links a {
      padding: 0.75rem 0;
      border-bottom: 1px solid #f0f0f0;
      width: 100%;
      font-size: 1rem;
    }
    .nav-links a:last-child { border-bottom: none; }
  }

  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    /* full width — no max-width, padding applied to sub-elements */
  }
  .hero-top {
    padding: 2.5rem var(--pad) 2rem;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: var(--black);
    margin: 0;
  }
  .hero-sub {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem var(--pad) 1.75rem;
    border-bottom: 1px solid var(--gray-mid);
  }
  .hero-sub-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hero-sub p {
    font-size: 0.875rem;
    color: var(--gray-text);
    margin: 0;
    line-height: 1.5;
  }
  .hero-date {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-text);
  }
  .hero-photo {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
  .hero-photo img {
    width: 100%;
    height: clamp(300px, 50vw, 580px);
    object-fit: cover;
    filter: grayscale(100%);
    display: block;
  }

  @media (max-width: 640px) {
    .hero-sub {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* ============================================================
     SECTION BASE
  ============================================================ */
  .section {
    padding: 5rem var(--pad);
    border-top: 1px solid var(--gray-mid);
  }

  .tag {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-text);
    margin: 0 0 2rem;
    display: block;
  }
  .tag-italic {
    font-style: italic;
    font-family: Georgia, serif;
    font-size: 0.85rem;
    text-transform: none;
    letter-spacing: 0;
  }

  /* ============================================================
     EL RUIDO
  ============================================================ */
  .noise-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  .noise-left p {
    font-size: 1rem;
    color: var(--gray-text);
    line-height: 1.75;
    margin: 0;
  }
  .noise-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .noise-stmt {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--black);
    line-height: 1.5;
    margin: 0;
  }
  .noise-rule {
    border: none;
    border-top: 1px solid var(--gray-mid);
    margin: 0;
  }

  @media (max-width: 768px) {
    .noise-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* ============================================================
     PROTOCOLO 4 DÍAS
  ============================================================ */
  .protocol-h {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: var(--black);
    margin: 0 0 3rem;
    letter-spacing: 0.02em;
    line-height: 1;
    font-weight: 400;
  }
  .protocol-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-left: 1px solid var(--gray-mid);
  }
  .protocol-card {
    border-right: 1px solid var(--gray-mid);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 300px;
  }
  .protocol-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    color: var(--gray-mid);
    line-height: 1;
  }
  .protocol-body { flex: 1; }
  .protocol-title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--black);
    margin: 0 0 0.3rem;
    letter-spacing: 0;
    line-height: 1.3;
  }
  .protocol-sub {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-text);
    margin: 0 0 0.85rem;
  }
  .protocol-desc {
    font-size: 0.92rem;
    color: var(--gray-text);
    line-height: 1.65;
    margin: 0;
  }
  .protocol-plus {
    font-size: 1.5rem;
    color: var(--gray-mid);
    font-weight: 300;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .protocol-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .protocol-grid { grid-template-columns: 1fr; }
  }

  /* ============================================================
     ARQUITECTURA DEL RETIRO
  ============================================================ */
  .arch-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1px;
    background: var(--gray-mid);
    border: 1px solid var(--gray-mid);
  }
  .arch-main {
    position: relative;
    overflow: hidden;
    line-height: 0;
  }
  .arch-main img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    filter: grayscale(100%);
    display: block;
  }
  .arch-label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white);
    background: rgba(0,0,0,0.5);
    padding: 0.3rem 0.6rem;
  }
  .arch-side {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 1px;
    background: var(--gray-mid);
  }
  .arch-card {
    background: var(--white);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .arch-card-dark {
    background: var(--black);
  }
  .arch-card-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
    color: var(--gray-text);
    font-weight: 600;
  }
  .arch-card-dark .arch-card-title {
    color: rgba(255,255,255,0.5);
  }
  .arch-card-desc {
    font-size: 0.88rem;
    color: var(--black);
    line-height: 1.5;
    margin: 0;
  }
  .arch-card-dark .arch-card-desc {
    color: var(--white);
  }

  @media (max-width: 768px) {
    .arch-grid { grid-template-columns: 1fr; }
    .arch-main img { height: 260px; }
    .arch-side { grid-template-rows: auto auto; }
  }

  /* ============================================================
     PRICING
  ============================================================ */
  .pricing-section { text-align: center; }
  .pricing-intro { color: #666; margin-bottom: 0; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 680px;
    margin: 2rem auto;
  }
  .price-card {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
  }
  .price-card.featured { background: #000; border-color: #000; color: #fff; }
  .room-title { font-size: 1.1rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.2rem; }
  .room-subtitle { font-size: 0.85rem; color: #888; margin-bottom: 1.25rem; }
  .price-card.featured .room-subtitle { color: rgba(255,255,255,0.55); }
  .price-amount { display: block; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 0.2rem; }
