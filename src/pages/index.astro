<script>
  (function () {
    const schedule = [
      {
        until: "2026-03-16",
        label: "Early bird",
        until_text: "hasta el 15 de marzo",
        discount: "30% de descuento",
        compartida: 442,
        individual: 558,
      },
      {
        until: "2026-04-16",
        label: "Segunda tanda",
        until_text: "hasta el 15 de abril",
        discount: "15% de descuento",
        compartida: 537,
        individual: 677,
      },
      {
        until: null,
        label: "Precio normal",
        until_text: "",
        discount: "",
        compartida: 632,
        individual: 797,
      },
    ];
    const now = new Date();
    const tier =
      schedule.find((t) => !t.until || now < new Date(t.until)) ||
      schedule[schedule.length - 1];
    const tierText = tier.until_text
      ? `${tier.label} — ${tier.until_text}`
      : tier.label;
    const set = (id, val) => {
      const el = document.getElementById(id);
      if (el) el.textContent = val;
    };
    set("price-compartida", tier.compartida + " EUR");
    set("price-individual", tier.individual + " EUR");
    set("tier-compartida", tierText);
    set("tier-individual", tierText);
    set("discount-compartida", tier.discount);
    set("discount-individual", tier.discount);

    // Countdown
    const countdownPhases = [
      {
        deadline: new Date("2026-03-16T00:00:00"),
        next: { compartida: 537, individual: 677 },
      },
      {
        deadline: new Date("2026-04-16T00:00:00"),
        next: { compartida: 632, individual: 797 },
      },
    ];
    const phase = countdownPhases.find((p) => now < p.deadline);
    if (phase) {
      const banner = document.getElementById("pricing-countdown");
      const labelEl = document.getElementById("countdown-label");
      const timerEl = document.getElementById("countdown-timer");
      const nextEl = document.getElementById("countdown-next");
      if (banner && labelEl && timerEl && nextEl) {
        banner.style.display = "flex";
        const deadlineDate = phase.deadline;
        const deadlineDay = deadlineDate.getDate() - 1;
        const deadlineMonth = deadlineDate.toLocaleString("es", {
          month: "long",
        });
        labelEl.textContent = `⏳ El precio sube el ${deadlineDay} de ${deadlineMonth} —`;
        nextEl.textContent = `Próximo precio: ${phase.next.compartida} € / ${phase.next.individual} €`;
        function pad(n: number) {
          return String(n).padStart(2, "0");
        }
        function tick() {
          const diff = deadlineDate.getTime() - Date.now();
          if (diff <= 0) {
            banner.style.display = "none";
            return;
          }
          const d = Math.floor(diff / 86400000);
          const h = Math.floor((diff % 86400000) / 3600000);
          const m = Math.floor((diff % 3600000) / 60000);
          const s = Math.floor((diff % 60000) / 1000);
          timerEl.textContent =
            d > 0
              ? `${d}d ${pad(h)}h ${pad(m)}m ${pad(s)}s`
              : `${pad(h)}h ${pad(m)}m ${pad(s)}s`;
        }
        tick();
        setInterval(tick, 1000);
      }
    }
  })();

  // Typing animation hero headline
  (function () {
    const line1El = document.getElementById("hero-line1");
    const line2El = document.getElementById("hero-line2");
    if (!line1El || !line2El) return;

    function typeText(el, text, speed, done) {
      el.textContent = "";
      let i = 0;
      const iv = setInterval(() => {
        el.textContent += text[i++];
        if (i >= text.length) {
          clearInterval(iv);
          if (done) done();
        }
      }, speed);
    }

    function eraseText(el, speed, done) {
      const iv = setInterval(() => {
        el.textContent = el.textContent.slice(0, -1);
        if (!el.textContent) {
          clearInterval(iv);
          if (done) done();
        }
      }, speed);
    }

    line1El.textContent = "LA IA AVANZA,";
    typeText(line2El, "¿TU TRABAJO TAMBIÉN?", 55, () => {
      setTimeout(() => {
        eraseText(line2El, 30, () => {
          line1El.textContent = "LA IA AVANZA.";
          typeText(line2El, "TU TRABAJO, TAMBIÉN.", 55, null);
        });
      }, 1800);
    });
  })();

  const toggle = document.querySelector(".nav-toggle");
  const nav = document.getElementById("home-nav");
  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      nav.classList.toggle("open");
    });
    document.addEventListener("click", (e) => {
      if (
        !toggle.contains(e.target as Node) &&
        !nav.contains(e.target as Node)
      ) {
        nav.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      }
    });
  }
</script>
