---
import { Image } from "astro:assets";
import heroPhoto from "../assets/images/ruralia-1.jpg";
import Base from "../layouts/Base.astro";

const linkCompartida = import.meta.env.PUBLIC_STRIPE_LINK_COMPARTIDA;
const linkIndividual = import.meta.env.PUBLIC_STRIPE_LINK_INDIVIDUAL;

const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "ruralGPT",
  url: "https://ruralgpt.gal",
  description:
    "Residencia inmersiva de IA aplicada para profesionales. 4 días en Galicia.",
  foundingDate: "2026",
  sameAs: [],
};

const days = [
  {
    num: "01",
    title: "¿Dónde estoy?",
    subtitle: "Mapa del terreno",
    desc: "Qué herramientas existen, para qué sirve cada una, cuáles son humo y cuáles merecen tu tiempo.",
  },
  {
    num: "02",
    title: "¿Qué puedo automatizar?",
    subtitle: "Tu trabajo bajo la lupa",
    desc: "Analizamos tu flujo de trabajo real. Qué tareas puedes automatizar, delegar a IA o hacer en la mitad de tiempo.",
  },
  {
    num: "03",
    title: "¿Puedo construir cosas?",
    subtitle: "De idea a prototipo",
    desc: "Aunque no sepas programar. Con Cursor, Bolt, Lovable y v0 construyes herramientas que antes habrías encargado.",
  },
  {
    num: "04",
    title: "¿Con qué me quedo?",
    subtitle: "Tu stack personalizado",
    desc: "Montas tu kit definitivo. Sales con todo configurado y listo para volver al trabajo con IA.",
  },
];

const inclusions = [
  "4 días de formación práctica",
  "3 noches de alojamiento",
  "Todas las comidas incluidas",
  "Materiales y licencias",
  "Comunidad alumni",
  "Sesión de seguimiento online",
];

const tools = [
  {
    name: "ChatGPT",
    desc: "Probablemente ya la uses. Aquí vas mucho más allá del 10% de su capacidad.",
    logo: "/logos/openai.svg",
    href: "https://chatgpt.com",
  },
  {
    name: "Claude",
    desc: "Para razonamiento y documentos largos. Mejor que ChatGPT para ciertas tareas.",
    logo: "/logos/anthropic.svg",
    href: "https://claude.ai",
  },
  {
    name: "Gemini",
    desc: "La IA de Google. Integrada con Gmail, Docs y Drive.",
    logo: "/logos/googlegemini.svg",
    href: "https://gemini.google.com",
  },
  {
    name: "Cursor",
    desc: "Escribe código con IA como copiloto. Aunque no sepas programar.",
    logo: "/logos/cursor.svg",
    href: "https://cursor.com",
  },
  {
    name: "Bolt",
    desc: "De idea a prototipo en minutos. Para validar antes de invertir tiempo.",
    logo: "/logos/bolt.svg",
    href: "https://bolt.new",
  },
  {
    name: "Lovable",
    desc: "Crea aplicaciones web completas describiendo lo que necesitas.",
    logo: "/logos/lovable.svg",
    href: "https://lovable.dev",
  },
  {
    name: "v0",
    desc: "Genera componentes de interfaz con una descripción. Para diseñadores y devs.",
    logo: "/logos/vercel.svg",
    href: "https://v0.dev",
  },
  {
    name: "Make",
    desc: "Automatiza flujos entre aplicaciones. Sin programar.",
    logo: "/logos/make.svg",
    href: "https://make.com",
  },
  {
    name: "Perplexity",
    desc: "Búsqueda con IA que cita las fuentes. Para investigar sin perderse.",
    logo: "/logos/perplexity.svg",
    href: "https://perplexity.ai",
  },
  {
    name: "NotebookLM",
    desc: "Convierte documentos en una base de conocimiento interactiva.",
    logo: "/logos/notebooklm.svg",
    href: "https://notebooklm.google.com",
  },
  {
    name: "Runway",
    desc: "Genera y edita vídeo con IA. Para los que trabajan con contenido.",
    logo: "/logos/runway.svg",
    href: "https://runwayml.com",
  },
  {
    name: "Kimi 2.5",
    desc: "Modelo open source potente de Moonshot AI. Para tareas avanzadas.",
    logo: "/logos/kimi.svg",
    href: "https://kimi.ai",
  },
];
---

<Base
  title="ruralGPT — Residencia inmersiva de IA aplicada en Galicia"
  description="4 días en Galicia para ponerte al día con IA. Formación práctica, alojamiento y comidas incluidas. 12 plazas. 3–7 junio 2026."
  keywords={[
    "residencia IA España",
    "curso IA inmersivo",
    "formación IA Galicia",
    "residencia inteligencia artificial",
  ]}
  schema={schema}
  hideHeader={true}
>
  <!-- ===== NAV ===== -->
  <header class="nav">
    <a href="/" class="nav-logo">
      <img
        src="/images/logo-ruralgpt.png"
        alt="ruralGPT"
        style="height:32px;width:auto;display:block;"
      />
    </a>
    <nav class="nav-links" id="home-nav">
      <a href="/residencia-ia-galicia/">Residencia IA</a>
      <a href="/para-quien/">Para quién</a>
      <a href="/blog/">Blog</a>
      <a href="/faq/">FAQ</a>
      <a href="/sobre-nosotros/">Quiénes somos</a>
    </nav>
    <a href="/#pricing" class="nav-cta">Reservar</a>
    <button
      class="nav-toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="home-nav"
    >
      <span></span>
      <span></span>
    </button>
  </header>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-top">
      <h1 class="hero-headline">
        <span id="hero-line1"></span><br />
        <span class="hero-headline-q" id="hero-line2"></span>
      </h1>
    </div>
    <div class="hero-sub">
      <div class="hero-sub-text">
        <p>
          <strong>La IA no te va a quitar el trabajo, pero un profesional que sabe
          usarla sí.</strong> Por eso esta residencia es un sprint para integrar IA en tu
          flujo de trabajo real. Sólo 12 profesionales podrán participar y
          <strong>la experiencia es un todo incluido</strong> desde la formación hasta el
          alojamiento, comida y ocio.
        </p>
        <p class="hero-date">
          3–7 de junio 2026 · <a
            href="https://anceu.com"
            target="_blank"
            rel="noopener">Anceu Coliving</a
          >
        </p>
      </div>
      <a href="/#pricing" class="btn-dark">Reserva tu plaza</a>
    </div>
    <div class="hero-photo">
      <Image
        src={heroPhoto}
        alt="Anceu Coliving entre árboles con niebla matutina en Galicia"
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <a href="/residencia-ia-galicia/" class="hero-learn-link">
      Aprende IA en 4 días en Galicia →
    </a>
  </section>

  <!-- ===== EL RUIDO ===== -->
  <section class="section noise">
    <div class="noise-grid">
      <div class="noise-left">
        <p class="tag">Qué es ruralGPT</p>
        <p>
          Una experiencia inmersiva de IA aplicada para profesionales. <strong>4 días en
          Galicia. Formación práctica, alojamiento y comidas incluidas.</strong> Grupos
          de 12 personas.
        </p>
      </div>
      <div class="noise-right">
        <p class="noise-stmt">
          No es un curso online. No es teoría. No es un máster de meses.
        </p>
        <hr class="noise-rule" />
        <p class="noise-stmt">
          Es trabajo real con herramientas reales aplicadas a tu trabajo.
        </p>
        <hr class="noise-rule" />
        <p class="noise-stmt">
          Llegas con dudas. Sales con tu stack configurado.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== PROTOCOLO 4 DÍAS ===== -->
  <section class="section protocol">
    <h2 class="protocol-h">
      No dejes que el ritmo de la tecnología te deje fuera del mercado.
    </h2>
    <p class="protocol-intro">
      Esto es lo que haremos en 4 días para que actualices tu stack profesional
      y recuperes el control de tu carrera con IA aplicada de verdad.
    </p>
    <div class="protocol-grid">
      {
        days.map((day) => (
          <div class="protocol-card">
            <span class="protocol-num">{day.num}</span>
            <div class="protocol-body">
              <h3 class="protocol-title">{day.title}</h3>
              <p class="protocol-sub">{day.subtitle}</p>
              <p class="protocol-desc">{day.desc}</p>
            </div>
            <span class="protocol-plus">+</span>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ===== HERRAMIENTAS ===== -->
  <section class="section tools">
    <p class="tag">Herramientas que aprenderás a usar</p>
    <div class="tools-grid">
      {
        tools.map((tool) => (
          <a
            class="tool-card"
            href={tool.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="tool-top">
              <img
                class="tool-logo"
                src={tool.logo}
                alt={tool.name}
                width="28"
                height="28"
                loading="lazy"
              />
              <span class="tool-arrow">↗</span>
            </div>
            <p class="tool-name">{tool.name}</p>
            <p class="tool-desc">{tool.desc}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- ===== DONDE VIVIRÁS ESTA EXPERIENCIA ===== -->
  <section class="section arch">
    <p class="tag">Dónde vivirás esta experiencia</p>
    <div class="arch-grid">
      <div class="arch-main">
        <img
          src="/images/room-102.webp"
          alt="Habitación 102 en Anceu Coliving"
          width="800"
          height="600"
          loading="lazy"
        />
      </div>
      <div class="arch-side">
        <div class="arch-card">
          <p class="arch-card-title">Habitación individual</p>
          <p class="arch-card-desc">
            Para ti solo. 3 noches incluidas en el precio.
          </p>
        </div>
        <div class="arch-card">
          <p class="arch-card-title">Habitación compartida</p>
          <p class="arch-card-desc">Máx. 2 personas. Opción más económica.</p>
        </div>
        <div class="arch-card arch-card-dark">
          <a
            class="arch-card-title arch-card-link"
            href="https://anceu.com"
            target="_blank"
            rel="noopener">Anceu Coliving ↗</a
          >
          <p class="arch-card-desc">
            Pontevedra, Galicia. 1 Gbps. A 30 min de la ciudad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PRICING ===== -->
  <section class="section" id="pricing">
    <div class="section-inner pricing-section">
      <h2>Precio</h2>
      <p class="pricing-intro">
        Todo incluido: formación, alojamiento, comidas y comunidad alumni.
      </p>
      <div
        class="pricing-grid"
        data-prices='[
          {"until":"2026-03-16","label":"Early bird","until_text":"hasta el 15 de marzo","discount":"30% de descuento","compartida":442,"individual":558},
          {"until":"2026-04-16","label":"Segunda tanda","until_text":"hasta el 15 de abril","discount":"15% de descuento","compartida":537,"individual":677},
          {"until":null,"label":"Precio normal","until_text":"","discount":"","compartida":632,"individual":797}
        ]'
      >
        <div class="price-card" id="card-compartida">
          <div class="room-title">Habitación compartida</div>
          <div class="room-subtitle">Compartida con otra persona</div>
          <span class="price-amount" id="price-compartida">442 EUR</span>
          <span class="price-tier" id="tier-compartida"
            >Early bird — hasta el 15 de marzo</span
          >
          <span class="price-discount" id="discount-compartida"
            >30% de descuento</span
          >
          <ul>
            <li>4 días de formación</li>
            <li>3 noches de alojamiento</li>
            <li>Todas las comidas</li>
            <li>Comunidad alumni</li>
            <li>Sesión follow-up</li>
          </ul>
          <p class="deposit-note">100 € ahora · resto antes de la llegada</p>
          <a
            href={linkCompartida}
            class="btn btn-primary"
            target="_blank"
            rel="noopener">Reserva por 100 €</a
          >
        </div>
        <div class="price-card featured" id="card-individual">
          <div class="room-title">Habitación individual</div>
          <div class="room-subtitle">Habitación para ti solo</div>
          <span class="price-amount" id="price-individual">558 EUR</span>
          <span class="price-tier" id="tier-individual"
            >Early bird — hasta el 15 de marzo</span
          >
          <span class="price-discount" id="discount-individual"
            >30% de descuento</span
          >
          <ul>
            <li>4 días de formación</li>
            <li>3 noches de alojamiento</li>
            <li>Todas las comidas</li>
            <li>Comunidad alumni</li>
            <li>Sesión follow-up</li>
          </ul>
          <p class="deposit-note">150 € ahora · resto antes de la llegada</p>
          <a
            href={linkIndividual}
            class="btn btn-gold"
            target="_blank"
            rel="noopener">Reserva por 150 €</a
          >
        </div>
      </div>
      <div
        id="pricing-countdown"
        style="display:none;"
        class="countdown-banner"
      >
        <span class="countdown-label" id="countdown-label"></span>
        <span class="countdown-timer" id="countdown-timer"></span>
        <span class="countdown-next" id="countdown-next"></span>
      </div>
    </div>
  </section>

  {/* ===== TESTIMONIALS (pendiente: añadir fotos y mensajes reales) =====
  <section class="section testimonials">
    <p class="tag">Lo que dicen quienes vivieron la experiencia Rural GPT</p>
    <div class="testi-grid">
      <div class="testi-card">
        <div class="testi-photo"></div>
        <p class="testi-quote">
          "Llegué sin saber por dónde empezar y salí con mi stack configurado y
          funcionando. En cuatro días hice más que en meses intentando aprender
          por mi cuenta."
        </p>
        <p class="testi-name">Laura M.</p>
        <p class="testi-role">Diseñadora gráfica freelance</p>
      </div>
      <div class="testi-card">
        <div class="testi-photo"></div>
        <p class="testi-quote">
          "No esperaba que fuera tan práctico. Cada ejercicio lo aplicaba
          directamente a mis proyectos reales. Volvería sin dudarlo."
        </p>
        <p class="testi-name">Carlos P.</p>
        <p class="testi-role">Consultor de marketing digital</p>
      </div>
      <div class="testi-card">
        <div class="testi-photo"></div>
        <p class="testi-quote">
          "El entorno lo cambia todo. Sin distracciones, con gente con las
          mismas dudas que tú. En cuatro días entiendes la IA de otra forma."
        </p>
        <p class="testi-name">Ana R.</p>
        <p class="testi-role">Gestora administrativa</p>
      </div>
    </div>
  </section>
  ===== /TESTIMONIALS ===== */}

  <!-- ===== GPT ===== -->
  <section class="section gpt-section">
    <div class="gpt-intro-wrap">
      <p class="gpt-intro">
        Millones de personas usan ChatGPT cada día. Tú le vas a dar un nuevo
        significado a estas letras.
      </p>
    </div>
    <div class="gpt-grid">
      <div class="gpt-col">
        <span class="gpt-letter">G</span>
        <h3>Generativo</h3>
        <p>
          No recupera información: la crea. Aprenderás a generar textos, ideas,
          código y prototipos que antes tardabas horas.
        </p>
      </div>
      <div class="gpt-col">
        <span class="gpt-letter">P</span>
        <h3>Preentrenado</h3>
        <p>
          Ha procesado más conocimiento del que podrás leer en tu vida.
          Aprenderás a aprovechar todo ese contexto para tu trabajo específico.
        </p>
      </div>
      <div class="gpt-col">
        <span class="gpt-letter">T</span>
        <h3>Transformador</h3>
        <p>
          El modelo transforma el lenguaje. La experiencia te transforma a ti.
          Sales con una forma distinta de trabajar.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CTA FINAL ===== -->
  <section class="cta-final">
    <h2 class="cta-headline">APRENDE IA.<br />EN 4 DÍAS.<br />EN GALICIA.</h2>
    <p class="cta-sub">
      Formación práctica, alojamiento y comidas incluidas. 12 plazas. Junio
      2026.
    </p>
    <a href="/#pricing" class="btn-cta-final">Reserva tu plaza</a>
  </section>

  <!-- ===== CONTACTO ===== -->
  <section class="section contact-section" id="contacto">
    <div class="section-inner contact-inner">
      <h2>¿Tienes dudas? Escríbenos</h2>
      <form
        class="contact-form"
        name="contacto"
        method="POST"
        data-netlify="true"
      >
        <input type="hidden" name="form-name" value="contacto" />
        <div class="contact-row">
          <input
            type="text"
            name="nombre"
            placeholder="Tu nombre"
            required
            class="contact-input"
          />
          <input
            type="email"
            name="email"
            placeholder="tu@email.com"
            required
            class="contact-input"
          />
        </div>
        <textarea
          name="mensaje"
          placeholder="Cuéntanos tu duda o situación..."
          rows="4"
          required
          class="contact-input contact-textarea"></textarea>
        <button type="submit" class="btn btn-primary">Enviar mensaje</button>
      </form>
    </div>
  </section>
</Base>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap");

  /* ============================================================
     TOKENS
  ============================================================ */
  :root {
    --black: #000000;
    --white: #ffffff;
    --gray-light: #f2f2f2;
    --gray-mid: #e0e0e0;
    --gray-text: #555555;
    --font-display: "Bebas Neue", sans-serif;
    --font-body: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
    --max: 1200px;
    --pad: clamp(1.5rem, 5vw, 4rem);
  }

  /* ============================================================
     NAV
  ============================================================ */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.25rem var(--pad);
    background: var(--white);
    border-bottom: 1px solid var(--gray-mid);
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--black);
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-right: auto;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    font-size: 0.85rem;
    color: var(--gray-text);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .nav-links a:hover {
    color: var(--black);
  }
  .nav-cta {
    background: #000;
    color: var(--white);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .nav-cta:hover {
    background: #222;
    color: #ffffff;
  }
  .nav-cta:active {
    background: #00a66b;
    color: #ffffff;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    flex-shrink: 0;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--black);
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }
    .nav-cta {
      display: none;
    }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 1px solid #e0e0e0;
      flex-direction: column;
      padding: 1rem clamp(1.5rem, 5vw, 4rem);
      gap: 0;
      z-index: 99;
    }
    .nav-links.open {
      display: flex;
    }
    .nav-links a {
      padding: 0.75rem 0;
      border-bottom: 1px solid #f0f0f0;
      width: 100%;
      font-size: 1rem;
    }
    .nav-links a:last-child {
      border-bottom: none;
    }
  }

  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    /* full width — no max-width, padding applied to sub-elements */
  }
  .hero-top {
    padding: 2.5rem var(--pad) 2rem;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: var(--black);
    margin: 0;
    min-height: calc(2 * clamp(3.5rem, 9vw, 8rem) * 0.95);
  }
  .hero-headline-q {
    color: var(--gray-text);
  }
  .hero-sub {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 1.25rem var(--pad) 1.75rem;
    border-bottom: 1px solid var(--gray-mid);
  }
  .hero-sub-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .hero-sub p {
    font-size: 0.875rem;
    color: var(--gray-text);
    margin: 0;
    line-height: 1.5;
  }
  .hero-date {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-text);
  }
  .hero-photo {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
  .hero-photo img {
    width: 100%;
    height: clamp(300px, 50vw, 580px);
    object-fit: cover;
    filter: grayscale(100%);
    display: block;
  }
  .hero-learn-link {
    display: block;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: #555;
    letter-spacing: 0.03em;
    text-decoration: none;
    padding: 1rem 0 0.5rem;
    transition: color 0.15s;
  }
  .hero-learn-link:hover {
    color: #000;
  }

  @media (max-width: 640px) {
    .hero-sub {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* ============================================================
     SECTION BASE
  ============================================================ */
  .section {
    padding: 5rem var(--pad);
    border-top: 1px solid var(--gray-mid);
  }

  .tag {
    font-size: 0.72rem;
