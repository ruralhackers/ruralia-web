---
import { Image } from 'astro:assets';
import heroPhoto from '../assets/images/ruralia-1.jpg';
import Base from '../layouts/Base.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'ruralGPT',
  url: 'https://ruralia.gal',
  description: 'Retiro inmersivo de IA aplicada para profesionales. 4 días en Galicia.',
  foundingDate: '2026',
  sameAs: [],
};

const days = [
  {
    num: '01',
    title: '¿Dónde estoy?',
    subtitle: 'Mapa del terreno',
    desc: 'Qué herramientas existen, para qué sirve cada una, cuáles son humo y cuáles merecen tu tiempo.',
  },
  {
    num: '02',
    title: '¿Qué puedo automatizar?',
    subtitle: 'Tu trabajo bajo la lupa',
    desc: 'Analizamos tu flujo de trabajo real. Qué tareas puedes automatizar, delegar a IA o hacer en la mitad de tiempo.',
  },
  {
    num: '03',
    title: '¿Puedo construir cosas?',
    subtitle: 'De idea a prototipo',
    desc: 'Aunque no sepas programar. Con Cursor, Bolt, Lovable y v0 construyes herramientas que antes habrías encargado.',
  },
  {
    num: '04',
    title: '¿Con qué me quedo?',
    subtitle: 'Tu stack personalizado',
    desc: 'Montas tu kit definitivo. Sales con todo configurado y listo para volver al trabajo con IA.',
  },
];

const team = [
  { name: 'Agustín Jamardo', bio: 'Fundador de Anceu Coliving. Desarrollador, 12+ años en remoto.' },
  { name: 'África Rodríguez', bio: 'Cofundadora de Rural Hackers. Facilitadora de proyectos europeos (Erasmus+).' },
  { name: 'Nacho Márquez', bio: 'Cofundador de Rural Hackers. Director de Noites Abertas. 20+ proyectos internacionales.' },
];

const inclusions = [
  '4 días de formación práctica',
  '3 noches de alojamiento',
  'Todas las comidas incluidas',
  'Materiales y licencias',
  'Comunidad alumni',
  'Sesión de seguimiento online',
];

const pricing = [
  { window: 'Antes del 15 de marzo', price: '628', discount: '30% de descuento', featured: false },
  { window: '16 marzo – 15 abril', price: '762', discount: '15% de descuento', featured: true },
  { window: 'Precio normal', price: '897', discount: '', featured: false },
];
---

<Base
  title="ruralGPT — Retiro inmersivo de IA aplicada en Galicia"
  description="4 días en Galicia para ponerte al día con IA. Formación práctica, alojamiento y comidas incluidas. 12 plazas. 3–7 junio 2026."
  keywords={['retiro IA España', 'curso IA inmersivo', 'formación IA Galicia', 'retiro inteligencia artificial']}
  schema={schema}
  hideHeader={true}
>

  <!-- ===== NAV ===== -->
  <header class="nav">
    <a href="/" class="nav-logo">ruralGPT</a>
    <nav class="nav-links">
      <a href="/retiro-ia-galicia/">El retiro</a>
      <a href="/para-quien/">Para quién</a>
      <a href="/blog/">Blog</a>
      <a href="/faq/">FAQ</a>
    </nav>
    <a href="/retiro-ia-galicia/#reservar" class="nav-cta">Reservar</a>
  </header>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-top">
      <h1 class="hero-headline">¿TE ACUERDAS DEL RINCÓN DEL VAGO?</h1>
      <div class="hero-meta">
        <p>Un retiro inmersivo de IA aplicada en Galicia. 4 días, 12 plazas, todo incluido.</p>
        <p class="hero-date">3 – 7 junio 2026 · Anceu Coliving, Pontevedra</p>
        <a href="/retiro-ia-galicia/#reservar" class="btn-dark">Reserva tu plaza</a>
      </div>
    </div>
    <div class="hero-photo">
      <Image
        src={heroPhoto}
        alt="Anceu Coliving entre árboles con niebla matutina en Galicia"
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  </section>

  <!-- ===== EL RUIDO ===== -->
  <section class="section noise">
    <div class="noise-grid">
      <div class="noise-left">
        <p class="tag">El ruido</p>
        <p>Cada semana salen 3 herramientas de IA nuevas. Los profesionales no tienen tiempo de probarlas. La brecha entre lo que saben y lo que deberían saber crece. No es falta de capacidad — es falta de horas.</p>
      </div>
      <div class="noise-right">
        <p class="noise-stmt">Todos los que usamos el Rincón del Vago recordamos esa sensación de alivio al encontrar el camino corto.</p>
        <hr class="noise-rule" />
        <p class="noise-stmt">Nuestra propuesta te hará sentir lo mismo, pero sin el miedo a que te pillen.</p>
        <hr class="noise-rule" />
        <p class="noise-stmt">En 4 días eliminarás la fatiga por herramientas: separar lo que funciona de lo que es humo.</p>
      </div>
    </div>
  </section>

  <!-- ===== PROTOCOLO 4 DÍAS ===== -->
  <section class="section protocol">
    <p class="tag">El protocolo de 4 días</p>
    <div class="protocol-grid">
      {days.map((day) => (
        <div class="protocol-card">
          <span class="protocol-num">{day.num}</span>
          <div class="protocol-body">
            <h3 class="protocol-title">{day.title}</h3>
            <p class="protocol-sub">{day.subtitle}</p>
            <p class="protocol-desc">{day.desc}</p>
          </div>
          <span class="protocol-plus">+</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== ARQUITECTURA DEL RETIRO ===== -->
  <section class="section arch">
    <p class="tag tag-italic">La arquitectura del retiro</p>
    <div class="arch-grid">
      <div class="arch-main">
        <Image
          src={heroPhoto}
          alt="Gastronomía gallega en Anceu"
          widths={[800, 1200]}
          sizes="(max-width: 768px) 100vw, 60vw"
          loading="lazy"
        />
        <span class="arch-label">Gastronomía gallega</span>
      </div>
      <div class="arch-side">
        <div class="arch-card">
          <p class="arch-card-title">Alojamiento</p>
          <p class="arch-card-desc">3 noches en Anceu Coliving. Habitación privada incluida.</p>
        </div>
        <div class="arch-card arch-card-dark">
          <p class="arch-card-title">Anceu Coliving</p>
          <p class="arch-card-desc">Pontevedra, Galicia. 1 Gbps. A 30 min de la ciudad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ADMISIÓN ===== -->
  <section class="section admission">
    <p class="tag">Admisión</p>
    <div class="admission-grid">
      {pricing.map((tier) => (
        <div class:list={['admission-card', { 'admission-featured': tier.featured }]}>
          <p class="admission-window">{tier.window}</p>
          <p class="admission-price">{tier.price} EUR</p>
          {tier.discount && <p class="admission-discount">{tier.discount}</p>}
          {!tier.discount && <p class="admission-discount">&nbsp;</p>}
          <ul class="admission-list">
            {inclusions.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a
            href="/retiro-ia-galicia/#reservar"
            class:list={[tier.featured ? 'btn-white' : 'btn-outline']}
          >
            Reservar plaza
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== EQUIPO ===== -->
  <section class="section team">
    <div class="team-grid">
      {team.map((person) => (
        <div class="team-card">
          <div class="team-photo"></div>
          <p class="team-name">{person.name}</p>
          <p class="team-bio">{person.bio}</p>
        </div>
      ))}
    </div>
  </section>

</Base>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap');

  /* ============================================================
     TOKENS
  ============================================================ */
  :root {
    --black: #000000;
    --white: #ffffff;
    --gray-light: #f2f2f2;
    --gray-mid: #e0e0e0;
    --gray-text: #555555;
    --font-display: 'Bebas Neue', sans-serif;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --max: 1200px;
    --pad: clamp(1.5rem, 5vw, 4rem);
  }

  /* ============================================================
     NAV
  ============================================================ */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem var(--pad);
    max-width: var(--max);
    margin: 0 auto;
  }
  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--black);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .nav-links {
    display: flex;
    gap: 2rem;
  }
  .nav-links a {
    font-size: 0.85rem;
    color: var(--gray-text);
    text-decoration: none;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--black); }
  .nav-cta {
    background: var(--black);
    color: var(--white);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .nav-cta:hover { opacity: 0.75; }

  @media (max-width: 768px) {
    .nav-links { display: none; }
  }

  /* ============================================================
     HERO
  ============================================================ */
  .hero {
    padding: 0 var(--pad);
    max-width: var(--max);
    margin: 0 auto 0;
  }
  .hero-top {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--gray-mid);
    margin-bottom: 0;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 9vw, 8rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: var(--black);
    margin: 0;
  }
  .hero-meta {
    max-width: 280px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 0.25rem;
  }
  .hero-meta p {
    font-size: 0.85rem;
    color: var(--gray-text);
    line-height: 1.5;
    margin: 0;
  }
  .hero-date {
    font-size: 0.75rem !important;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-text) !important;
    margin-bottom: 0.5rem !important;
  }
  .hero-photo {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }
  .hero-photo img {
    width: 100%;
    height: clamp(300px, 50vw, 580px);
    object-fit: cover;
    filter: grayscale(100%);
    display: block;
  }

  @media (max-width: 640px) {
    .hero-top {
      grid-template-columns: 1fr;
    }
    .hero-meta { max-width: 100%; }
  }

  /* ============================================================
     SECTION BASE
  ============================================================ */
  .section {
    padding: 5rem var(--pad);
    max-width: var(--max);
    margin: 0 auto;
    border-top: 1px solid var(--gray-mid);
  }

  .tag {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gray-text);
    margin: 0 0 2rem;
    display: block;
  }
  .tag-italic {
    font-style: italic;
    font-family: Georgia, serif;
    font-size: 0.85rem;
    text-transform: none;
    letter-spacing: 0;
  }

  /* ============================================================
     EL RUIDO
  ============================================================ */
  .noise-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  .noise-left p {
    font-size: 0.95rem;
    color: var(--gray-text);
    line-height: 1.75;
    margin: 0;
  }
  .noise-right {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .noise-stmt {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--black);
    line-height: 1.6;
    margin: 0;
  }
  .noise-rule {
    border: none;
    border-top: 1px solid var(--gray-mid);
    margin: 0;
  }

  @media (max-width: 768px) {
    .noise-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* ============================================================
     PROTOCOLO 4 DÍAS
  ============================================================ */
  .protocol-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-left: 1px solid var(--gray-mid);
  }
  .protocol-card {
    border-right: 1px solid var(--gray-mid);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-height: 280px;
  }
  .protocol-num {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--gray-mid);
    line-height: 1;
  }
  .protocol-body { flex: 1; }
  .protocol-title {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--black);
    margin: 0 0 0.2rem;
    letter-spacing: 0;
    line-height: 1.3;
  }
  .protocol-sub {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray-text);
    margin: 0 0 0.75rem;
  }
  .protocol-desc {
    font-size: 0.82rem;
    color: var(--gray-text);
    line-height: 1.6;
    margin: 0;
  }
  .protocol-plus {
    font-size: 1.25rem;
    color: var(--gray-mid);
    font-weight: 300;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .protocol-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .protocol-grid { grid-template-columns: 1fr; }
  }

  /* ============================================================
     ARQUITECTURA DEL RETIRO
  ============================================================ */
  .arch-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 1px;
    background: var(--gray-mid);
    border: 1px solid var(--gray-mid);
  }
  .arch-main {
    position: relative;
    overflow: hidden;
    line-height: 0;
  }
  .arch-main img {
    width: 100%;
    height: 400px;
    object-fit: cover;
    filter: grayscale(100%);
    display: block;
  }
  .arch-label {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white);
    background: rgba(0,0,0,0.5);
    padding: 0.3rem 0.6rem;
  }
  .arch-side {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 1px;
    background: var(--gray-mid);
  }
  .arch-card {
    background: var(--white);
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .arch-card-dark {
    background: var(--black);
  }
  .arch-card-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 0.5rem;
    color: var(--gray-text);
    font-weight: 600;
  }
  .arch-card-dark .arch-card-title {
    color: rgba(255,255,255,0.5);
  }
  .arch-card-desc {
    font-size: 0.88rem;
    color: var(--black);
    line-height: 1.5;
    margin: 0;
  }
  .arch-card-dark .arch-card-desc {
    color: var(--white);
  }

  @media (max-width: 768px) {
    .arch-grid { grid-template-columns: 1fr; }
    .arch-main img { height: 260px; }
    .arch-side { grid-template-rows: auto auto; }
  }

  /* ============================================================
     ADMISIÓN
  ============================================================ */
  .admission-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--gray-mid);
    border: 1px solid var(--gray-mid);
  }
  .admission-card {
    background: var(--white);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .admission-featured {
    background: var(--black);
  }
  .admission-window {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--gray-text);
    margin: 0 0 1rem;
  }
  .admission-featured .admission-window {
    color: rgba(255,255,255,0.5);
  }
  .admission-price {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--black);
    line-height: 1;
    margin: 0 0 0.25rem;
    letter-spacing: 0.02em;
  }
  .admission-featured .admission-price {
    color: var(--white);
  }
  .admission-discount {
    font-size: 0.75rem;
    color: var(--gray-text);
    margin: 0 0 1.75rem;
    min-height: 1rem;
  }
  .admission-featured .admission-discount {
    color: rgba(255,255,255,0.5);
  }
  .admission-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .admission-list li {
    font-size: 0.82rem;
    color: var(--gray-text);
    padding-left: 1rem;
    position: relative;
    line-height: 1.4;
  }
  .admission-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--gray-mid);
  }
  .admission-featured .admission-list li {
    color: rgba(255,255,255,0.65);
  }
  .admission-featured .admission-list li::before {
    color: rgba(255,255,255,0.25);
  }

  @media (max-width: 768px) {
    .admission-grid { grid-template-columns: 1fr; }
  }

  /* ============================================================
     BUTTONS
  ============================================================ */
  .btn-dark {
    display: inline-block;
    background: var(--black);
    color: var(--white);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.7rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.15s;
    align-self: flex-start;
    margin-top: 0.5rem;
  }
  .btn-dark:hover { opacity: 0.75; color: var(--white); }

  .btn-outline {
    display: block;
    border: 1px solid var(--gray-mid);
    color: var(--black);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.7rem 1.5rem;
    text-align: center;
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
  }
  .btn-outline:hover { border-color: var(--black); color: var(--black); }

  .btn-white {
    display: block;
    background: var(--white);
    color: var(--black);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.7rem 1.5rem;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-white:hover { opacity: 0.85; color: var(--black); }

  /* ============================================================
     EQUIPO
  ============================================================ */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
  }
  .team-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .team-photo {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: var(--gray-light);
    border: 1px solid var(--gray-mid);
  }
  .team-name {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--black);
    margin: 0;
    font-style: italic;
  }
  .team-bio {
    font-size: 0.82rem;
    color: var(--gray-text);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .team-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
