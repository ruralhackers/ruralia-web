<script>
  (function () {
    const schedule = [
      { until: '2026-03-16', label: 'Early bird', until_text: 'hasta el 15 de marzo', discount: '30% de descuento', compartida: 442, individual: 558 },
      { until: '2026-04-16', label: 'Segunda tanda', until_text: 'hasta el 15 de abril', discount: '15% de descuento', compartida: 537, individual: 677 },
      { until: null, label: 'Precio normal', until_text: '', discount: '', compartida: 632, individual: 797 },
    ];
    const now = new Date();
    const tier = schedule.find((t) => !t.until || now < new Date(t.until)) || schedule[schedule.length - 1];
    const tierText = tier.until_text ? `${tier.label} — ${tier.until_text}` : tier.label;
    const set = (id, val) => { const el = document.getElementById(id); if (el) el.textContent = val; };
    set('price-compartida', tier.compartida + ' EUR');
    set('price-individual', tier.individual + ' EUR');
    set('tier-compartida', tierText);
    set('tier-individual', tierText);
    set('discount-compartida', tier.discount);
    set('discount-individual', tier.discount);
  })();

  const toggle = document.querySelector('.nav-toggle');
  const nav = document.getElementById('home-nav');
  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('open');
    });
    document.addEventListener('click', (e) => {
      if (!toggle.contains(e.target as Node) && !nav.contains(e.target as Node)) {
        nav.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>

