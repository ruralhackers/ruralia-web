---
const year = new Date().getFullYear();

const links = [
  { href: '/retiro-ia-galicia/', label: 'El retiro' },
  { href: '/para-quien/', label: 'Para quién' },
  { href: '/blog/', label: 'Blog' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/sobre-nosotros/', label: 'Sobre nosotros' },
];

const legalLinks = [
  { href: '/legal/', label: 'Aviso legal' },
  { href: '/legal/#privacidad', label: 'Privacidad' },
];
---

<footer class="footer">
  <div class="footer-top">
    <a href="/" class="footer-logo">
      <img src="/images/logo-ruralgpt.png" alt="ruralGPT" style="height:28px;width:auto;display:block;" />
    </a>
    <nav class="footer-nav" aria-label="Footer">
      {links.map(({ href, label }) => (
        <a href={href}>{label}</a>
      ))}
    </nav>
  </div>
  <div class="footer-bottom">
    <p class="footer-copy">&copy; {year} ruralGPT</p>
    <div class="footer-bottom-right">
      <a href="mailto:hola@ruralgpt.gal">hola@ruralgpt.gal</a>
      {legalLinks.map(({ href, label }) => (
        <a href={href}>{label}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid #e0e0e0;
    background: #ffffff;
    padding: 3rem clamp(1.5rem, 5vw, 4rem) 2rem;
  }
  .footer-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e0e0e0;
    margin-bottom: 1.5rem;
  }
  .footer-logo {
    font-family: 'Bebas Neue', 'Inter', sans-serif;
    font-size: 1.5rem;
    color: #000000;
    text-decoration: none;
    letter-spacing: 0.02em;
    line-height: 1;
    flex-shrink: 0;
  }
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.4rem 2rem;
  }
  .footer-nav a {
    font-size: 0.85rem;
    color: #555555;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }
  .footer-nav a:hover {
    color: #000000;
  }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .footer-copy {
    font-size: 0.78rem;
    color: #999999;
    margin: 0;
  }
  .footer-bottom-right {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .footer-bottom-right a {
    font-size: 0.78rem;
    color: #999999;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-bottom-right a:hover {
    color: #000000;
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
    }
    .footer-nav {
      justify-content: flex-start;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
